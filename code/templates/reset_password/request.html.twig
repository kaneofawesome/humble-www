{% extends 'base.html.twig' %}

{% block title %}Forgot Password - Humble{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-container">
        <div class="auth-card">
            <h1 class="auth-title">Forgot Password</h1>
            <p class="auth-subtitle">Enter your email and we'll send you a reset link</p>

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger">{{ flash_error }}</div>
            {% endfor %}

            {{ form_start(requestForm, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">
                    {{ form_label(requestForm.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(requestForm.email, {'attr': {'class': 'form-input', 'placeholder': 'you@example.com', 'autofocus': true}}) }}
                    {{ form_errors(requestForm.email) }}
                </div>

                <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
            {{ form_end(requestForm) }}

            <div class="auth-footer">
                <p>Remember your password? <a href="{{ path('app_login') }}">Sign in</a></p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
