{% extends 'base.html.twig' %}

{% block title %}Change Password - Humble{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-container">
        <div class="auth-card">
            <h1 class="auth-title">Change Password</h1>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">
                    {{ form_label(form.currentPassword, 'Current Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.currentPassword, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.currentPassword) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.newPassword.first, 'New Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'At least 8 characters'}}) }}
                    {{ form_errors(form.newPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.newPassword.second, 'Confirm New Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.newPassword.second) }}
                </div>

                {{ form_errors(form) }}

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Update Password</button>
                    <a href="{{ path('app_profile') }}" class="btn btn-outline">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</section>
{% endblock %}
